{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/list", "destination": "/list.html" },
    { "source": "/api/list", "destination": "/api/list.js" },
    { "source": "/api/upload", "destination": "/api/upload.js" },
    { "source": "/image/:folder/:filename", "destination": "/api/view.js?file=:folder/:filename" },
    { "source": "/image/:filename", "destination": "/api/view.js?file=:filename" }
  ]
}
